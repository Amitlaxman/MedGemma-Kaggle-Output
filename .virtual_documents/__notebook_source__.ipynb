"""
MedGemma 4B Fine-Tuning for Silicosis Report Generation
Using QLoRA on Kaggle T4 GPU (16GB VRAM)

Training data: Set B — 443 paired chest X-ray images + docx radiology reports
Task: Given a chest X-ray image → generate structured clinical report

Report format (from docx files):
    EXAMINATION: CHEST (PA)
    FINDINGS: [detailed findings]
    Impression: [Silicosis / Silicotuberculosis / Tuberculosis / Normal]

OOM prevention techniques applied:
    1. 4-bit NF4 quantization (BitsAndBytesConfig)
    2. fp32 compute dtype — NOT bfloat16 (T4 doesn't support bfloat16 in PyTorch grad scaler)
    3. Gradient checkpointing
    4. batch_size=1 + gradient_accumulation=8
    5. max_new_tokens capped at 400
    6. Image resized to 512x512 before processing
    7. torch.cuda.empty_cache() between steps

Prerequisites:
    1. Accept MedGemma terms at huggingface.co/google/medgemma-4b-it
    2. Add HF_TOKEN to Kaggle Secrets (Add-ons → Secrets)
    3. Enable GPU in notebook settings (T4 x1)

Install cell (run first):
    get_ipython().getoutput("pip install transformers accelerate bitsandbytes peft trl -q")
"""

import os
import re
import zipfile
import torch
import pandas as pd
from PIL import Image
from torch.utils.data import Dataset
from torch.nn.utils.rnn import pad_sequence




# ─────────────────────────────────────────────
# PATHS
# ─────────────────────────────────────────────
DATA_ROOT = "/kaggle/input/datasets/skratta/silicodata/Silicodata_Updated_Feb2025"
SET_B_DIR     = os.path.join(DATA_ROOT, "set_B_folder")
SET_B_IMAGES  = os.path.join(SET_B_DIR, "set_B_images")
SET_B_REPORTS = os.path.join(SET_B_DIR, "set_B_reports")
SET_B_CSV     = os.path.join(SET_B_DIR, "Silicodata_SetB_labels.csv")

OUTPUT_DIR   = "/kaggle/working/medgemma_silicosis"
ADAPTER_DIR  = "/kaggle/working/medgemma_silicosis_adapter"

os.makedirs(OUTPUT_DIR,  exist_ok=True)
os.makedirs(ADAPTER_DIR, exist_ok=True)

MODEL_ID = "google/medgemma-4b-it"





# ─────────────────────────────────────────────
# STEP 1: PARSE DOCX REPORTS
# No pip install needed — uses zipfile (built-in)
# ─────────────────────────────────────────────
def parse_docx(path):
    """
    Extract text from a .docx file using zipfile (no python-docx needed).
    Returns cleaned plain text.
    """
    try:
        with zipfile.ZipFile(path) as z:
            with z.open("word/document.xml") as f:
                content = f.read().decode("utf-8")
        text = re.sub(r'<[^>]+>', ' ', content)
        text = re.sub(r'\s+', ' ', text).strip()
        return text
    except Exception as e:
        return None


def clean_report(raw_text):
    """
    Extract the relevant clinical content from raw docx XML text.
    Keeps everything from EXAMINATION to end of Impression.
    """
    if not raw_text:
        return None

    # Find from EXAMINATION onwards
    match = re.search(r'(EXAMINATION.*)', raw_text, re.DOTALL | re.IGNORECASE)
    if match:
        text = match.group(1)
    else:
        text = raw_text

    # Clean up extra whitespace
    text = re.sub(r'\s+', ' ', text).strip()

    # Must contain FINDINGS and Impression to be valid
    if 'FINDINGS' not in text.upper() or 'IMPRESSION' not in text.upper():
        return None

    # Cap length — very long reports cause OOM
    if len(text) > 1200:
        text = text[:1200]

    return text


def build_report_dataset():
    """
    Match set_B_images to set_B_reports by patient ID.
    Returns list of dicts: {image_path, report_text, patient_id}
    """
    # Build image lookup: patient_id_lower → full path
    available_images = {}
    for fname in os.listdir(SET_B_IMAGES):
        if fname.lower().endswith((".jpg", ".jpeg", ".png")):
            pid = os.path.splitext(fname)[0].lower()
            available_images[pid] = os.path.join(SET_B_IMAGES, fname)

    # Build report lookup: patient_id_lower → full path
    available_reports = {}
    for fname in os.listdir(SET_B_REPORTS):
        if fname.lower().endswith(".docx"):
            pid = os.path.splitext(fname)[0].lower()
            available_reports[pid] = os.path.join(SET_B_REPORTS, fname)

    print(f"Images found  : {len(available_images)}")
    print(f"Reports found : {len(available_reports)}")

    samples = []
    skipped_no_image  = 0
    skipped_no_report = 0
    skipped_bad_report = 0

    for pid, report_path in available_reports.items():
        # Find matching image
        img_path = available_images.get(pid, None)
        if img_path is None:
            skipped_no_image += 1
            continue

        # Parse and clean report
        raw  = parse_docx(report_path)
        text = clean_report(raw)
        if text is None:
            skipped_bad_report += 1
            continue

        samples.append({
            "patient_id"  : pid,
            "image_path"  : img_path,
            "report_text" : text,
        })

    print(f"\nMatched pairs      : {len(samples)}")
    print(f"Skipped no image   : {skipped_no_image}")
    print(f"Skipped no report  : {skipped_no_report}")
    print(f"Skipped bad report : {skipped_bad_report}")

    # Show 2 examples
    for s in samples[:2]:
        print(f"\n--- {s['patient_id']} ---")
        print(s['report_text'][:300])

    return samples





# ─────────────────────────────────────────────
# STEP 2: PYTORCH DATASET
# ─────────────────────────────────────────────
class SilicoReportDataset(Dataset):
    """
    Returns raw samples — collation handled by custom collate_fn.
    Keeps images as PIL to avoid pre-loading all into RAM.
    """
    def __init__(self, samples):
        self.samples = samples

    def __len__(self):
        return len(self.samples)

    def __getitem__(self, idx):
        s = self.samples[idx]
        # Resize to 512x512 — reduces VRAM vs full resolution
        img = Image.open(s["image_path"]).convert("RGB").resize((512, 512))
        return {
            "image"      : img,
            "report_text": s["report_text"],
        }





# ─────────────────────────────────────────────
# STEP 3: COLLATE FUNCTION
# Builds chat-formatted inputs for MedGemma
# ─────────────────────────────────────────────
SYSTEM_PROMPT = (
    "You are an expert radiologist specializing in occupational lung disease "
    "in mining workers. Generate a structured chest X-ray report."
)

USER_PROMPT = (
    "Analyze this chest X-ray from a mining worker. "
    "Generate a structured clinical report including: "
    "examination type, findings (nodules, fibrosis, consolidation, "
    "hilar changes, pleural changes, emphysema, cavity, bronchiectasis), "
    "and final impression (Silicosis / Silicotuberculosis / Tuberculosis / Normal)."
)

def make_collate_fn(processor):
    def collate_fn(batch):
        all_inputs = []
        for item in batch:
            messages = [
                {
                    "role": "user",
                    "content": [
                        {"type": "image", "image": item["image"]},
                        {"type": "text",  "text": USER_PROMPT},
                    ],
                },
                {
                    "role": "assistant",
                    "content": [
                        {"type": "text", "text": item["report_text"]},
                    ],
                },
            ]
            inputs = processor.apply_chat_template(
                messages,
                add_generation_prompt=False,
                tokenize=True,
                return_dict=True,
                return_tensors="pt",
                truncation=True,
                max_length=1024,
            )
            all_inputs.append(inputs)

        # Stack all keys
        result = {}
        
        for key in all_inputs[0].keys():
        
            # pixel_values usually already same shape
            if key == "pixel_values":
                result[key] = torch.cat([x[key] for x in all_inputs], dim=0)
        
            else:
                tensors = [x[key].squeeze(0) for x in all_inputs]
        
                pad_value = 0
        
                # labels/input_ids should use tokenizer pad token
                if key in ["input_ids", "attention_mask"]:
                    pad_value = processor.tokenizer.pad_token_id or 0
        
                padded = pad_sequence(
                    tensors,
                    batch_first=True,
                    padding_value=pad_value
                )
        
                result[key] = padded

        # Build labels
        labels = result["input_ids"].clone()
        
        # Ignore padding
        labels[result["attention_mask"] == 0] = -100

        # Mask everything EXCEPT the assistant response
        # From diagnostic:
        #   token id=105 = <start_of_turn>  ← assistant turn starts here
        #   token id=106 = <end_of_turn>
        #   token id=107 = newline after turn marker
        # Assistant response = tokens AFTER the LAST occurrence of id=105

        START_OF_TURN = 105   # <start_of_turn>

        for i in range(labels.shape[0]):
            input_ids_row = result["input_ids"][i]
            seq_len = input_ids_row.shape[0]

            # Find the LAST occurrence of <start_of_turn>
            # This is where the assistant turn begins
            last_start_pos = -1
            for j in range(seq_len):
                if input_ids_row[j].item() == START_OF_TURN:
                    last_start_pos = j

            if last_start_pos != -1:
                # Mask everything up to and including:
                # <start_of_turn>(105) + "model"(4368) + newline(107)
                # = 3 tokens after last_start_pos
                mask_until = last_start_pos + 3
                labels[i, :mask_until] = -100
            else:
                # Fallback: mask first 60%
                labels[i, :int(seq_len * 0.6)] = -100

        result["labels"] = labels

        # Verify masking on first sample (remove after confirming it works)
        valid_label_count = (labels[0] != -100).sum().item()

        return result

    return collate_fn




# ─────────────────────────────────────────────
# STEP 4: LOAD MODEL WITH QLORA
# ─────────────────────────────────────────────
def load_model_and_processor(hf_token):
    from transformers import AutoProcessor, AutoModelForImageTextToText, BitsAndBytesConfig
    from peft import LoraConfig, get_peft_model

    print("\nLoading processor ...")
    processor = AutoProcessor.from_pretrained(MODEL_ID, token=hf_token)

    print("Loading model with 4-bit quantization ...")
    # CRITICAL: fp32 compute dtype on T4 — bfloat16 causes NotImplementedError
    bnb_config = BitsAndBytesConfig(
        load_in_4bit=True,
        bnb_4bit_quant_type="nf4",
        bnb_4bit_use_double_quant=True,
        bnb_4bit_compute_dtype=torch.float32,   # NOT bfloat16 on Kaggle T4
    )

    model = AutoModelForImageTextToText.from_pretrained(
        MODEL_ID,
        token=hf_token,
        quantization_config=bnb_config,
        device_map="auto",
        low_cpu_mem_usage=True,
        attn_implementation="eager",
    )

    # Gradient checkpointing — reduces activation memory significantly
    model.gradient_checkpointing_enable()

    print("Applying LoRA adapters ...")
    lora_config = LoraConfig(
        r=16,              # rank — safe default for structured output task
        lora_alpha=32,
        # Target attention projections only — keeps memory low
        target_modules=["q_proj", "v_proj", "k_proj", "o_proj"],
        lora_dropout=0.05,
        bias="none",
        task_type="CAUSAL_LM",
    )
    model = get_peft_model(model, lora_config)
    model.print_trainable_parameters()
                    
    return model, processor





# ─────────────────────────────────────────────
# STEP 5: TRAINING
# ─────────────────────────────────────────────
def train(model, processor, samples):
    from transformers import TrainingArguments, Trainer

    dataset     = SilicoReportDataset(samples)
    collate_fn  = make_collate_fn(processor)

    # 80/20 train/val split
    split       = int(0.8 * len(dataset))
    train_ds    = torch.utils.data.Subset(dataset, range(split))
    val_ds      = torch.utils.data.Subset(dataset, range(split, len(dataset)))
    print(f"\nTrain: {len(train_ds)}  Val: {len(val_ds)}")

    training_args = TrainingArguments(
        output_dir=OUTPUT_DIR,

        # Batch config — batch_size=1 is mandatory on T4 with 4B model + images
        per_device_train_batch_size=1,
        per_device_eval_batch_size=1,
        gradient_accumulation_steps=8,    # effective batch = 8

        num_train_epochs=5,
        learning_rate=2e-5,
        warmup_steps=35,
        lr_scheduler_type="cosine",

        # Precision — 
        fp16=False,
        bf16=False,

        #gradient clipping
        max_grad_norm=0.3, 
        # Memory optimizations
        gradient_checkpointing=True,
        dataloader_pin_memory=False,      # saves CPU RAM
        dataloader_num_workers=0,         # avoids multiprocessing issues on Kaggle

        # Logging and saving
        logging_steps=40,
        eval_strategy="epoch",
        save_strategy="epoch",
        load_best_model_at_end=True,
        metric_for_best_model="eval_loss",
        greater_is_better=False,

        report_to="none",
        remove_unused_columns=False,      # CRITICAL for multimodal — don't remove pixel_values
    )

    trainer = Trainer(
        model=model,
        args=training_args,
        train_dataset=train_ds,
        eval_dataset=val_ds,
        data_collator=collate_fn,
    )

    print("\nStarting training ...")

    trainer.train()
    return trainer





# ─────────────────────────────────────────────
# STEP 6: SAVE ADAPTER
# ─────────────────────────────────────────────
def save_adapter(model, processor):
    print(f"\nSaving LoRA adapter to {ADAPTER_DIR} ...")
    model.save_pretrained(ADAPTER_DIR)
    processor.save_pretrained(ADAPTER_DIR)
    print("Saved. Download from Kaggle output tab.")
    print(f"Adapter size: ~50-100MB (much smaller than full model)")





# ─────────────────────────────────────────────
# STEP 7: INFERENCE — generate report for new image
# ─────────────────────────────────────────────
def generate_report(model, processor, image_path, max_new_tokens=350):
    """
    Generate a clinical report for a chest X-ray.

    Usage after training:
        report = generate_report(model, processor, "/path/to/xray.jpg")
        print(report)
    """
    model.eval()
    img = Image.open(image_path).convert("RGB").resize((512, 512))

    messages = [
        {
            "role": "user",
            "content": [
                {"type": "image", "image": img},
                {"type": "text",  "text": USER_PROMPT},
            ],
        }
    ]

    inputs = processor.apply_chat_template(
        messages,
        add_generation_prompt=True,
        tokenize=True,
        return_dict=True,
        return_tensors="pt",
    ).to(model.device)

    with torch.inference_mode():
        outputs = model.generate(
            **inputs,
            max_new_tokens=max_new_tokens,
            do_sample=False,           # deterministic output
            temperature=None,
            top_p=None,
        )

    input_len = inputs["input_ids"].shape[-1]
    report    = processor.decode(outputs[0][input_len:], skip_special_tokens=True)
    return report.strip()





# ─────────────────────────────────────────────
# STEP 8: LOAD SAVED ADAPTER FOR INFERENCE
# ─────────────────────────────────────────────
def load_finetuned_model(hf_token):
    """
    Load the fine-tuned model for inference after training.
    Run this in a fresh notebook session.
    """
    from transformers import AutoProcessor, AutoModelForImageTextToText, BitsAndBytesConfig
    from peft import PeftModel

    bnb_config = BitsAndBytesConfig(
        load_in_4bit=True,
        bnb_4bit_quant_type="nf4",
        bnb_4bit_use_double_quant=True,
        bnb_4bit_compute_dtype=torch.float32,
    )

    processor = AutoProcessor.from_pretrained(MODEL_ID, token=hf_token)

    base_model = AutoModelForImageTextToText.from_pretrained(
        MODEL_ID,
        token=hf_token,
        quantization_config=bnb_config,
        device_map="auto",
        low_cpu_mem_usage=True,
    )

    model = PeftModel.from_pretrained(base_model, ADAPTER_DIR)
    model.eval()
    print("Fine-tuned model loaded.")
    return model, processor





