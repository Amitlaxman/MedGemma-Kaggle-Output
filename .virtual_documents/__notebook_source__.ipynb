        )

    # Step 2: Load model
    print("\n" + "="*50)
    print("STEP 2: Loading MedGemma-4B with QLoRA")
    print("="*50)
    model, processor = load_model_and_processor(hf_token)

    # Step 3: Train
    print("\n" + "="*50)
    print("STEP 3: Fine-tuning")
    print("="*50)
    trainer = train(model, processor, samples)

    # Step 4: Save adapter
    save_adapter(model, processor)

